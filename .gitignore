# --------------------------
# 1. 构建/输出目录（必排除）
# --------------------------
dist/**
build/**
out/**
output/**
release/**
target/**
bin/**
obj/**
frontend@tmp/**/*
banks/ext-hnnxbank@tmp/**/*
ext-hnnxbank@tmp/**/*

# --------------------------
# 2. 依赖库（必排除）
# --------------------------
**/node_modules/**
vendor/**
venv/**
__pycache__/**
*.pyc
*.pyo
*.pyd
.Python
lib/**
lib64/**

# --------------------------
# 3. 日志、临时、缓存（必排除）
# --------------------------
*.log
*.logs
log/**
logs/**
*.tmp
*.temp
.cache/**
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --------------------------
# 4. 测试、覆盖率、报告（建议排除）
# --------------------------
**/test/**
**/tests/**
**/__tests__/**
**/coverage/**
*.test.js
*.spec.js
**/test-results/**
**/perf/**
*.dump

# --------------------------
# 5. 媒体、大文件（关键提速）
# --------------------------
**/*.png
**/*.jpg
**/*.jpeg
**/*.gif
**/*.svg
**/*.mp4
**/*.mov
**/*.avi
**/*.zip
**/*.rar
**/*.tar.gz
**/*.iso
**/*.bin
**/*.exe
**/*.dll
**/*.so
**/*.dylib

# --------------------------
# 6. 项目相关
# --------------------------
.idea
.vscode

# --------------------------
# 7. 敏感信息
# --------------------------
**/.env
**/*.env
**/credentials
**/secrets
**/.ssh/

# --------------------------
# 8. 编译输出
# --------------------------
**/*.class
**/*.jar
**/*.war
**/*.ear

# --------------------------
# 9. IDE 特定文件
# --------------------------
*.iml
*.ipr
*.iws

{
  "name": "default_mindmap",
  "type": "mindmap",
  "version": "1.0.0",
  "description": "默认思维导图模板",
  "style": {
    "theme": "default",
    "fontFamily": "Microsoft YaHei, SimSun, sans-serif",
    "fontSize": 14,
    "lineHeight": 1.5,
    "color": {
      "text": "#333333",
      "background": "#ffffff",
      "border": "#cccccc"
    },
    "layout": {
      "spacing": 40,
      "levelSpacing": 80,
      "siblingSpacing": 30
    }
  },
  "structure": {
    "root": {
      "text": "中心主题",
      "style": {
        "fontColor": "#ffffff",
        "backgroundColor": "#1e88e5",
        "borderColor": "#1565c0",
        "fontSize": 18,
        "bold": true
      }
    },
    "levels": [
      {
        "level": 1,
        "style": {
          "fontColor": "#ffffff",
          "backgroundColor": "#42a5f5",
          "borderColor": "#1e88e5",
          "fontSize": 16,
          "bold": true
        }
      },
      {
        "level": 2,
        "style": {
          "fontColor": "#333333",
          "backgroundColor": "#e3f2fd",
          "borderColor": "#90caf9",
          "fontSize": 14,
          "bold": false
        }
      },
      {
        "level": 3,
        "style": {
          "fontColor": "#333333",
          "backgroundColor": "#f5f5f5",
          "borderColor": "#bdbdbd",
          "fontSize": 13,
          "bold": false
        }
      },
      {
        "level": 4,
        "style": {
          "fontColor": "#333333",
          "backgroundColor": "#f0f0f0",
          "borderColor": "#9e9e9e",
          "fontSize": 12,
          "bold": false
        }
      }
    ]
  },
  "icons": {
    "enabled": true,
    "default": "fa fa-circle",
    "level1": "fa fa-star",
    "level2": "fa fa-check",
    "level3": "fa fa-info"
  },
  "colors": [
    "#1e88e5",
    "#42a5f5",
    "#64b5f6",
    "#90caf9",
    "#e3f2fd"
  ]
}

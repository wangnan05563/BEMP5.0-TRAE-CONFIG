{
  "name": "bemp-advanced-doc-generator",
  "version": "2.0.0",
  "description": "BEMP 高级文档生成器 - 支持详细设计文档、测试用例、测试报告、Excel SIT测试用例自动生成",
  "main": "cli.js",
  "scripts": {
    "generate": "node cli.js",
    "generate:design": "node cli.js -t design",
    "generate:testcase": "node cli.js -t testcase",
    "generate:testcase-excel": "node cli.js -t testcase -f excel",
    "generate:testreport": "node cli.js -t testreport"
  },
  "dependencies": {
    "docx": "^8.5.0",
    "exceljs": "^4.4.0",
    "axios": "^1.6.0",
    "dotenv": "^16.3.0"
  }
}

# BEMP Webapp Testing - 运行时生成文件
# 这些文件/目录由测试脚本自动生成，不应纳入版本控制

# 会话状态（storage_state 持久化）
session_states/

# 测试报告（自动生成）
reports/*.json
reports/*.md
reports/*.html
!reports/.gitkeep

# 测试截图（自动生成）
test-data/screenshots/*.png
test-data/screenshots/*.json

# 日志文件
*.log

# Python 缓存
__pycache__/
*.pyc
*.pyo

# 测试输出临时文件
*.tmp
.temp/